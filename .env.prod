APP_ENV=prod

###> symfony/messenger ###
# In production, use Redis for async message processing
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
###< symfony/messenger ###

###> nelmio/cors-bundle ###
# Replace with your actual frontend domain in production
CORS_ALLOW_ORIGIN='^https://your-frontend-domain\.com$'
###< nelmio/cors-bundle ###
